# NodeBrain Backend Environment Variables
# Copy this to .env and customize

# Server
PORT=3001

# Vault encryption key — change this to something secret before production use
VAULT_SECRET=change-this-to-a-long-random-secret-string

# Optional: Default OpenAI model override
# DEFAULT_MODEL=gpt-4o-mini

# Google OAuth — each user must create their own Google Cloud project
# See docs/google-oauth-setup.md for instructions
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback