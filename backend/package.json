{
  "name": "nodebrain-backend",
  "version": "1.0.0",
  "description": "NodeBrain local AI agent engine",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:prod": "npx pm2 start ecosystem.config.cjs && npx pm2 save",
    "stop": "npx pm2 stop nodebrain",
    "restart": "npx pm2 restart nodebrain",
    "logs": "npx pm2 logs nodebrain",
    "status": "npx pm2 status",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@xenova/transformers": "^2.17.2",
    "chrono-node": "^2.9.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "pdfjs-dist": "^5.6.205",
    "sql.js": "^1.11.0",
    "uuid": "^9.0.1",
    "vectra": "^0.12.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.20",
    "@types/node-cron": "^3.0.11",
    "@types/sql.js": "^1.4.9",
    "@types/uuid": "^9.0.8",
    "pm2": "^6.0.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.9.3"
